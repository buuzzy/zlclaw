{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sage",
  "version": "1.3.0",
  "identifier": "ai.sage.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "",
        "width": 1200,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "sage"
        ]
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IERGOEQxMEM5NzBCMzMyMDEKUldRQk1yTnd5UkNOMzFMbmZVcThiZHRGUzdqNyt0bnF1dllMK2hrejRIM0FselpodmZTcTBDdHoK",
      "endpoints": [
        "https://github.com/buuzzy/sage/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "../src-api/dist/sage-api"
    ],
    "macOS": {
      "entitlements": "entitlements.plist"
    },
    "resources": {
      "../src-api/resources": "resources"
    }
  }
}
