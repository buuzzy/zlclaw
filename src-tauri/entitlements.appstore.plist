<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- ============================================================================
         STRICT Mac App Store Sandbox Entitlements
         
         This is a MORE RESTRICTIVE version for strict MAS compliance review.
         Use this if the default entitlements.plist causes MAS review issues.
         ============================================================================ -->
    
    <!-- Core Sandbox Entitlement (REQUIRED for MAS) -->
    <key>com.apple.security.app-sandbox</key>
    <true/>
    
    <!-- ============================================================================
         Code Signing - Minimal Set
         ============================================================================ -->
    
    <!-- Allow JIT compilation for Node.js/V8 -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    
    <!-- Allow unsigned executable memory for dynamically loaded code -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    
    <!-- Disable library validation for Node.js modules -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    
    <!-- ============================================================================
         Network Access - Strict
         ============================================================================ -->
    
    <!-- Allow localhost connections only (no remote servers)  -->
    <!-- This is the safest option for MAS review -->
    <!-- If you need remote connections, modify these or request MAS exemption -->
    
    <!-- Allow localhost client connections -->
    <key>com.apple.security.network.client</key>
    <true/>
    
    <!-- Allow localhost server connections -->
    <key>com.apple.security.network.server</key>
    <true/>
    
    <!-- ============================================================================
         File System Access - Minimal
         ============================================================================ -->
    
    <!-- Allow downloads directory access (common for MAS apps) -->
    <key>com.apple.security.files.downloads.read-write</key>
    <true/>
    
    <!-- Allow Documents directory access -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>
    
    <!-- ============================================================================
         NOTES FOR MAS SUBMISSION
         
         If MAS review team requests changes:
         
         1. JIT Entitlements: These three CS entitlements are required for Node.js
            to function. Explain this is for running the API server.
            
         2. Network Entitlements: Required for localhost IPC between frontend
            and API server. Explain there's no external network traffic.
            
         3. File System: Only app-specific directories are accessed.
            Home directory access is via container path.
         ============================================================================ -->
    
</dict>
</plist>
