<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- ============================================================================
         Mac App Store Sandbox - Required Entitlements for macOS
         
         Apple requires the app-sandbox entitlement for all MAS apps.
         This enables the macOS sandbox security model.
         ============================================================================ -->
    
    <!-- Core Sandbox Entitlement -->
    <key>com.apple.security.app-sandbox</key>
    <true/>

    <!-- App Store Identity -->
    <key>com.apple.application-identifier</key>
    <string>QB576QUT2S.ai.sage.desktop</string>
    <key>com.apple.developer.team-identifier</key>
    <string>QB576QUT2S</string>

    <!-- ============================================================================
         Code Signing and Execution
         
         Required for Node.js sidecar process and JavaScript/WebAssembly execution
         ============================================================================ -->
    
    <!-- Allow JIT compilation for Node.js/V8 -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    
    <!-- Allow unsigned executable memory for dynamically loaded code -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    
    <!-- Disable library validation for Node.js modules -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    
    <!-- ============================================================================
         Network Access
         
         Required for API server on localhost and external service connections
         ============================================================================ -->
    
    <!-- Allow localhost network connections (for internal API) -->
    <key>com.apple.security.network.client</key>
    <true/>
    
    <!-- Allow incoming network connections (for serving requests) -->
    <key>com.apple.security.network.server</key>
    <true/>
    
    <!-- ============================================================================
         File System Access
         
         Restricted by sandbox but configured for app-specific directories
         ============================================================================ -->
    
    <!-- Allow read/write to user documents -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>
    
    <!-- ============================================================================
         REMOVED FOR MAS COMPLIANCE
         
         These entitlements are NOT compatible with Mac App Store:
         - com.apple.security.hypervisor
         - com.apple.security.virtualization
         
         If you need VM functionality in the future, use an alternative approach
         (e.g., manage VMs externally via sidecar without these entitlements)
         ============================================================================ -->
    
</dict>
</plist>
